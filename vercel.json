*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial,sans-serif;color:#142033;background:#f6f8ff;line-height:1.6}.site-header{position:sticky;top:0;z-index:50;display:flex;justify-content:space-between;align-items:center;gap:24px;padding:18px min(6vw,72px);background:rgba(8,17,31,.92);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.1)}.brand{font-weight:900;color:#fff;text-decoration:none}nav{display:flex;gap:22px;align-items:center;flex-wrap:wrap}nav a{color:#c8d3e6;text-decoration:none;font-size:14px;font-weight:700}nav a:hover{color:#58d8ff}.nav-btn{padding:10px 16px;border:1px solid rgba(255,255,255,.2);border-radius:999px}.hero{display:grid;grid-template-columns:1.15fr .85fr;gap:56px;align-items:center;padding:95px min(6vw,72px);background:radial-gradient(circle at 12% 0%,rgba(88,216,255,.28),transparent 34%),radial-gradient(circle at 88% 10%,rgba(151,124,255,.24),transparent 30%),#08111f;color:white}.eyebrow{margin:0 0 12px;color:#58d8ff;text-transform:uppercase;letter-spacing:.16em;font-size:13px;font-weight:900}.eyebrow.dark{color:#176c98}h1,h2,h3{line-height:1.08;margin:0 0 18px}h1{font-size:clamp(42px,7vw,76px);letter-spacing:-2px}h2{font-size:clamp(32px,4vw,52px);letter-spacing:-1px}h3{font-size:22px}.lead,.section-lead{font-size:20px;color:#c8d3e6;max-width:740px}.section-lead{color:#526078}.actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:30px}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:0 22px;border-radius:999px;font-weight:900;text-decoration:none;border:1px solid transparent}.btn.primary{background:linear-gradient(135deg,#58d8ff,#9b7cff);color:#06101e}.btn.secondary{border-color:rgba(255,255,255,.25);color:white}.dark-btn{margin-top:16px}.book-feature{justify-self:center;width:min(360px,100%);padding:28px;border-radius:30px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);box-shadow:0 24px 80px rgba(0,0,0,.35)}.book-cover{aspect-ratio:2/3;border-radius:20px;background:linear-gradient(160deg,#05101f,#15345a 52%,#0aa8cc);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:28px;box-shadow:inset 0 0 90px rgba(255,255,255,.1)}.book-cover span{letter-spacing:.35em;color:#c8d3e6}.book-cover strong{font-size:38px;line-height:1;margin:16px 0}.book-cover small{color:#dff8ff}.rating{text-align:center;color:#ffe38a;font-weight:800}.section{padding:86px min(6vw,72px)}.split{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}.checks{padding-left:22px}.checks li{margin:10px 0}.qr-card,.card{background:white;border:1px solid #dde5f3;border-radius:28px;padding:28px;box-shadow:0 18px 50px rgba(19,34,59,.08)}.qr-card{text-align:center;max-width:370px;justify-self:center}.qr-card img{width:min(260px,100%);height:auto;border-radius:18px;border:10px solid #f3f6fb}.qr-card p{color:#526078}.blue{background:#08111f;color:white}.blue h2{max-width:760px}.grid,.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:34px}.grid article{padding:24px;border-radius:24px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12)}.grid p{color:#c8d3e6}.card p{color:#526078}.about{background:white}.author-photo{width:260px;height:260px;border-radius:50%;display:grid;place-items:center;justify-self:center;background:linear-gradient(135deg,#10213b,#58d8ff);color:white;font-size:64px;font-weight:900;box-shadow:0 20px 70px rgba(12,29,56,.2)}.cta{text-align:center;background:linear-gradient(135deg,#10213b,#09111f);color:white}.cta p{color:#c8d3e6;font-size:19px}footer{text-align:center;padding:28px;background:#050a13;color:#aebbd0}@media(max-width:820px){.site-header{align-items:flex-start;flex-direction:column}.hero,.split{grid-template-columns:1fr}.hero{padding-top:70px}nav{gap:12px}.grid,.cards{grid-template-columns:1fr}.book-feature{justify-self:start}.qr-card{justify-self:start}h1{font-size:42px}}